DISCORD_TOKEN=your_discord_bot_token
DISCORD_GUILD_ID=123456789012345678
ALLOWED_USER_IDS=123456789012345678,987654321098765432
DISCORD_NOTIFY_CHANNEL_ID=123456789012345678

# Twitter/X 専用アカウントの認証情報（スクレイピング用）
TWITTER_USERNAME=your_x_username_or_email
TWITTER_PASSWORD=your_x_password
# Playwright セッションキャッシュファイルのパス（デフォルト: twitter_session.json）
# TWITTER_SESSION_PATH=twitter_session.json

PROMO_DB_PATH=promo.db
ASSETS_DIR=assets
PROMPTS_DIR=prompts
CLAUDE_TIMEOUT=120
SCHEDULER_POLL_SECONDS=30
# 自動アナリティクスの実行間隔（時間）。この間隔ごとにツイートメトリクスを取得して蓄積する
ANALYTICS_FETCH_INTERVAL_HOURS=6

# Web UI / API
WEB_BASE_URL=https://void2610.dev
API_PORT=8080
# Next.js → FastAPI 通信（サーバーサイド専用変数・NEXT_PUBLIC_ は付けない）
# Docker Compose 環境では http://api:8080 が自動設定されるため通常変更不要
API_INTERNAL_URL=http://localhost:8080
# CORS 許可オリジン（カンマ区切り）
CORS_ALLOWED_ORIGINS=http://localhost:3000,https://void2610.dev

# Docker / Claude CLI
# Claude CLI 認証ファイルのホスト側パス（デフォルト: ~/.claude）
# macOS の場合は /Users/<username>/.claude を明示的に設定することを推奨
CLAUDE_CONFIG_DIR=~/.claude

# Cloudflare Tunnel（docker compose --profile tunnel up の場合のみ必要）
TUNNEL_TOKEN=your_cloudflare_tunnel_token
